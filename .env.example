# ArchTech Suite — Environment Variables
# Copy to .env and adjust for local development
# WARNING: Never commit .env to git

# Drupal
CUSTOM_THEME_NAME=front_theme
THEME_FRAMEWORK=tailwind
DRUPAL_HASH_SALT=local-dev-salt-change-in-production
DRUPAL_TRUSTED_HOST_PATTERNS='^.+\.ddev\.site$|^localhost$'

# Database
DATABASE_URL=postgresql://db:db@postgres:5432/db
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=db
DATABASE_USER=db
DATABASE_PASSWORD=db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=archtech
RABBITMQ_PASS=archtech
RABBITMQ_VHOST=/

# AI Providers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Vault
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=
VAULT_ROLE=drupal

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_SERVICE_NAME=archtech-drupal
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
PROMETHEUS_RETENTION=15d
LOKI_RETENTION=72h

# Feature Flags (Redis-backed)
FEATURE_FLAG_STORE=redis
FEATURE_FLAG_PREFIX=archtech:feature_flags

# DDEV
DDEV_SITENAME=archtech
DDEV_PROJECT_TYPE=drupal11
DDEV_PHP_VERSION=8.4
DDEV_DATABASE=postgres:18

# CI/CD (GitHub Actions - only set in CI)
# SNYK_TOKEN=
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
# KUBECONFIG=
# CODEGOV_TOKEN=
