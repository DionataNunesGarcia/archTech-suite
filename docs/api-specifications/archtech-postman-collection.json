            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"João Silva\",\"email\":\"joao@exemplo.com\",\"phone\":\"5511999999999\",\"company\":\"Construtora ABC\",\"score\":8,\"status\":\"new\"}"
