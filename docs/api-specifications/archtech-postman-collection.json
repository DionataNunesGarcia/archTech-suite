    {
      "name": "Platform",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Trace-Id", "value": "{{trace_id}}" }],
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
          }
        },
        {
          "name": "API Health",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Trace-Id", "value": "{{trace_id}}" }],
            "url": { "raw": "{{base_url}}/api/health", "host": ["{{base_url}}"], "path": ["api", "health"] }
          }
